{
  "expo": {
    "name": "procrastino",
    "slug": "procrastino",
    "version": "1.0.0",
    "scheme": "procrastino",
    "orientation": "portrait",
    "icon": "./assets/Logo.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7EEDF",
        "foregroundImage": "./assets/Logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/Logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-status-bar"
    ]
  }
}
